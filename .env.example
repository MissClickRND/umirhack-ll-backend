# App
PORT=3000
BACKEND_HOST_PORT=3000

# Postgres (for docker-compose.prod.yml)
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=backend_db

# IMPORTANT: in Docker use host `postgres`, not localhost
DATABASE_URL=postgresql://admin:change_me_strong_password@postgres:5432/backend_db

# Symmetric key for encrypting diploma fields (full name, reg. number); must match across restarts
DIPLOMA_SYMMETRIC_KEY=a1b2c3d4e5f6789012345678abcdef0123456789abcdef0123456789abcdef00

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_very_long
JWT_REFRESH_SECRET=change_me_refresh_secret_very_long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Cookies (set true behind HTTPS)
COOKIE_SECURE=true
COOKIE_SAMESITE=none
COOKIE_DOMAIN=miss-click.ru
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://miss-click.ru,https://miss-click.ru,https://www.miss-click.ru
CORS_CREDENTIALS=true
