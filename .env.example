п»ҝ# App
PORT=3000
BACKEND_HOST_PORT=3000

# Postgres (for docker-compose.prod.yml)
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=backend_db

# IMPORTANT: in Docker use host `postgres`, not localhost
DATABASE_URL=postgresql://admin:change_me_strong_password@postgres:5432/backend_db

# Symmetric key for encrypting diploma fields (full name, reg. number); must match across restarts
DIPLOMA_SYMMETRIC_KEY=a1b2c3d4e5f6789012345678abcdef0123456789abcdef0123456789abcdef00
# In-memory cache for diploma reads (invalidated on batch create / status update / QR token create)
DIPLOMA_CACHE_TTL_MS=120000

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_very_long
JWT_REFRESH_SECRET=change_me_refresh_secret_very_long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Cookies (set true behind HTTPS)
COOKIE_SECURE=true
COOKIE_SAMESITE=none
COOKIE_DOMAIN=miss-click.ru
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token

# CORS
# CORS_ORIGINS РІРӮвҖқ РЎвҖҡР С•Р В»РЎРҠР С”Р С• Р РҶР В°РЎвӮ¬Р С‘ РЎвҖһРЎРӮР С•Р Р…РЎвҖҡРЎвҖ№ (cookies + fetch РЎРғ credentials: 'include').
# Р РҺ Р В»РЎРӢР ВұРЎвҖ№РЎвҖҰ РЎвҖЎРЎС“Р В¶Р С‘РЎвҖҰ Р Т‘Р С•Р СҳР ВөР Р…Р С•Р РҶ Р С‘Р В· Р ВұРЎРӮР В°РЎС“Р В·Р ВөРЎРӮР В° Р С•РЎвҖҡР С”РЎРӮРЎвҖ№РЎвҖҡ РЎвҖҡР С•Р В»РЎРҠР С”Р С• POST /employer/public/verify (Р ВұР ВөР В· Р Т‘Р С•Р ВұР В°Р РҶР В»Р ВөР Р…Р С‘РЎРҸ Р С‘РЎвҖҰ Р РҶ РЎРғР С—Р С‘РЎРғР С•Р С”).
# Р СӣРЎРғРЎвҖҡР В°Р В»РЎРҠР Р…РЎвҖ№Р Вө Р С—РЎС“Р ВұР В»Р С‘РЎвҖЎР Р…РЎвҖ№Р Вө GET (Р Р…Р В°Р С—РЎРӮР С‘Р СҳР ВөРЎРӮ /diplomas/search) РЎРғ РЎвҖЎРЎС“Р В¶Р С•Р С–Р С• РЎРғР В°Р в„–РЎвҖҡР В° РЎвҖЎР ВөРЎРӮР ВөР В· fetch Р Р…Р Вө Р С—РЎРӮР С•Р в„–Р Т‘РЎС“РЎвҖҡ CORS.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://miss-click.ru,https://miss-click.ru,https://www.miss-click.ru
CORS_CREDENTIALS=true
