generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    schemas  = ["posts"]
}

model Post {
    id        Int      @id @default(autoincrement())
    userId    String
    title     String
    content   String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([userId])
    @@schema("posts")
}
