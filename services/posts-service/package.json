{
  "name": "posts-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run prisma:generate && tsc -p tsconfig.build.json",
    "start": "npm run start:prod",
    "start:dev": "npm run prisma:generate && npm run prisma:push && ts-node-dev --respawn --transpile-only src/main.ts",
    "start:prod": "npm run prisma:generate && npm run prisma:push && node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.6.1",
    "prisma": "^7.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.23",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
