generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    schemas  = ["auth"]
}

enum Role {
    ADMIN
    WAITER
    COOK
    CUSTOMER

    @@schema("auth")
}

model User {
    id                 Int      @id @default(autoincrement())
    name               String?
    email              String   @unique
    phone              String?  @unique
    passwordHash       String
    hashedRefreshToken String?
    tokenVersion       Int      @default(0)
    role               Role     @default(CUSTOMER)
    createdAt          DateTime @default(now())
    updatedAt          DateTime @updatedAt

    @@schema("auth")
}
