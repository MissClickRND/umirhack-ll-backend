generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  HR
  NEED_VERIFICATION
  UNIVERSITY
  STUDENT
}

model User {
  id                 Int      @id @default(autoincrement())
  email              String   @unique
  passwordHash       String
  hashedRefreshToken String? // может быть null (если не залогинен)
  tokenVersion       Int      @default(0)
  role               Role     @default(HR)
  universityId       String?
  university         University? @relation(fields: [universityId], references: [id], onDelete: SetNull)
  diplomas           Diploma[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model University {
  id                    String   @id @default(uuid())
  name                  String
  shortName             String?  @unique
  publicKey             String?
  encryptedPrivateKey   String?
  encryptedSymmetricKey String?
  users                 User[]
  diplomas              Diploma[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Diploma {
  id                 String     @id @default(uuid())
  fullNameUser       String
  universityId       String
  university         University @relation(fields: [universityId], references: [id], onDelete: Restrict)
  userId             Int?
  user               User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  registrationNumber String
  issuedAt           DateTime
  specialty          String
  degreeLevel        String
  status             String
  signature          String
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([universityId])
  @@index([userId])
}
