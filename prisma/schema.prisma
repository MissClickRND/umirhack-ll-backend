generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  HR
  NEED_VERIFICATION
  UNIVERSITY
  STUDENT
}

model User {
  id                 Int         @id @default(autoincrement())
  email              String      @unique
  passwordHash       String
  hashedRefreshToken String?
  tokenVersion       Int         @default(0)
  role               Role        @default(HR)
  organizationId     Int?        @map("organization_id")
  organization       University? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  pendingUniversityName      String? @map("pending_university_name")
  pendingUniversityShortName String? @map("pending_university_short_name")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  diplomas  Diploma[]
}

model Diploma {
  id Int @id @default(autoincrement())

  fullNameAuthorEncrypted     String @map("full_name_author")
  registrationNumberEncrypted String @map("registration_number")
  registrationNumberHash      String @unique @map("registration_number_hash")

  userId Int?  @map("user_id")
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  universityId Int        @map("university_id")
  university   University @relation(fields: [universityId], references: [id], onDelete: Restrict)

  issuedAt DateTime @map("issued_at")

  specialty   String
  degreeLevel DegreeLevel @map("degree_level")

  status DiplomaStatus

  signature String @default("") @map("signature")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tokens DiplomaToken[]

  @@map("diplomas")
}

model DiplomaToken {
  id Int @id @default(autoincrement())

  diplomaId Int    @map("diploma_id")
  tokenHash String @unique @map("token_hash")

  expiresAt DateTime? @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  isOneTime  Boolean   @default(false) @map("is_one_time")
  lastUsedAt DateTime? @map("last_used_at")

  createdAt DateTime @default(now()) @map("created_at")

  diploma Diploma @relation(fields: [diplomaId], references: [id])

  @@map("diploma_tokens")
}

model University {
  id Int @id @default(autoincrement())

  name      String  @unique
  shortName String? @map("short_name")

  publicKey             String? @map("public_key")
  encryptedPrivateKey   String? @map("encrypted_private_key")
  encryptedSymmetricKey String? @map("encrypted_symmetric_key")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users    User[]
  diplomas Diploma[]

  @@map("universities")
}

enum DiplomaStatus {
  VALID
  REVOKED
}

enum DegreeLevel {
  BACHELOR
  MAGISTRACY
  SPECIALIST
  DOCTORATE
}
